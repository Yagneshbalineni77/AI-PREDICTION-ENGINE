# ==========================================
# Dextora Foresight Environment Configuration
# ==========================================
# Copy this file to .env and fill in your keys.
# The backend will not start if LLM_API_KEY is missing.

# 1. LLM API Configuration (REQUIRED)
# We use Gemini API via its OpenAI compatibility layer.
# Get your Gemini API key from: https://aistudio.google.com/app/apikey
LLM_API_KEY=your_gemini_api_key_here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL_NAME=gemini-1.5-pro

# 2. GraphStore Configuration (OPTIONAL)
# The application uses a local SQLite database for graph memory by default.
# The ZEP_API_KEY is NO LONGER required. Leave this empty unless you specifically 
# modified the code to use the Zep Cloud service.
ZEP_API_KEY=

# 3. Server Configuration
# Set to false for production to avoid security risks
FLASK_DEBUG=false
SECRET_KEY=change_this_to_a_random_string_for_production